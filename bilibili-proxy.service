[Unit]
Description=VRChat BPlayer Proxy
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/bilibili-proxy
ExecStart=/usr/bin/python3 /opt/bilibili-proxy/main.py
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1
Environment=API_TOKEN=thechwinlyu
Environment=WEB_PASSWORD=admin
Environment=FFMPEG_PATH=/usr/bin/ffmpeg

[Install]
WantedBy=multi-user.target
